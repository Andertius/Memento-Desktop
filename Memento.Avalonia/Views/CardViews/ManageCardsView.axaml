<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:vm="clr-namespace:Memento.Core.ViewModels.CardViewModels;assembly=Memento.Core"
             xmlns:interfaces="clr-namespace:Memento.Core.Interfaces.ViewModels.CardViewModels;assembly=Memento.Core"
             xmlns:labs="clr-namespace:Avalonia.Labs.Controls;assembly=Avalonia.Labs.Controls"
             xmlns:converters="clr-namespace:Memento.Avalonia.Converters"
             xmlns:dd="clr-namespace:Memento.Avalonia.DesignTime"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="500"
             Background="{DynamicResource PrimaryBackground}"
             d:DataContext="{x:Static dd:DesignData.ManageCardsViewModel}"
             x:Class="Memento.Avalonia.Views.CardViews.ManageCardsView"
             x:DataType="interfaces:IManageCardsViewModel"
             x:Name="CardsList">

    <UserControl.Resources>
        <converters:EmptyStringIfEmptyConverter x:Key="EmptyStringIfEmptyConverter" />
        <system:String x:Key="CategoriesString">Categories: </system:String>
        <system:String x:Key="TagsString">Tags: </system:String>
    </UserControl.Resources>

    <Grid>
        <Border Padding="20">
            <Grid RowDefinitions="75 *" RowSpacing="20">
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Card Management" FontSize="26" HorizontalAlignment="Center" />

                    <StackPanel Orientation="Horizontal">
                        <Button HorizontalAlignment="Left" Classes="add-item-button" Command="{Binding CreateCardCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <materialIcons:MaterialIcon Kind="Plus" />

                                <TextBlock Text="Add" FontSize="18" />
                            </StackPanel>
                        </Button>

                        <!-- <TextBox HorizontalAlignment="Right" /> -->
                    </StackPanel>
                </StackPanel>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Cards}"
                                  Background="Transparent">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="10" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:CardViewModel">
                                <Button BorderBrush="{DynamicResource ItemBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="4"
                                        Width="300"
                                        Command="{Binding ElementName=CardsList, Path=DataContext.EditCardCommand, FallbackValue={x:Null}}"
                                        CommandParameter="{Binding}">
                                    <StackPanel>
                                        <Panel Height="275" Width="275">
                                            <Rectangle Fill="{DynamicResource ImageBackdrop}" />

                                            <labs:AsyncImage PlaceholderSource="/Assets/placeholder.png"
                                                             Margin="20"
                                                             MaxHeight="350"
                                                             MaxWidth="350"
                                                             Source="{Binding ImageUrl}" />
                                        </Panel>

                                        <TextBlock Text="{Binding Word}" HorizontalAlignment="Center" FontSize="22" />

                                        <Separator />

                                        <StackPanel Orientation="Horizontal" Margin="10 0">
                                            <TextBlock Text="{Binding CombinedCategories, Converter={StaticResource EmptyStringIfEmptyConverter}, ConverterParameter={StaticResource CategoriesString}}" />
                                            <TextBlock Text="{Binding CombinedCategories}" />
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="10 0">
                                            <TextBlock Text="{Binding CombinedTags, Converter={StaticResource EmptyStringIfEmptyConverter}, ConverterParameter={StaticResource TagsString}}" />
                                            <TextBlock Text="{Binding CombinedTags}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid IsVisible="{Binding DialogViewModel.IsDialogOpen, FallbackValue=false}">
            <Border Padding="25" Background="Black" Opacity="0.5" />

            <ContentControl Content="{Binding DialogViewModel}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
        </Grid>
    </Grid>
</UserControl>
