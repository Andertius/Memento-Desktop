<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:vm="clr-namespace:Memento.Core.Interfaces.ViewModels;assembly=Memento.Core"
        xmlns:data="clr-namespace:Memento.Core.Data;assembly=Memento.Core"
        xmlns:converters="clr-namespace:Memento.Avalonia.Converters"
        xmlns:dd="clr-namespace:Memento.Avalonia.DesignTime"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        d:DataContext="{x:Static dd:DesignData.MainViewModel}"
        x:Class="Memento.Avalonia.Views.MainView"
        x:DataType="vm:IMainViewModel"
        Icon="/Assets/icon.png"
        Title="Memento">

    <Window.Resources>
        <converters:ActivePageConverter x:Key="ActivePageConverter" />
    </Window.Resources>

    <Grid Background="{DynamicResource PrimaryBackground}" ColumnDefinitions="300, *">
        <Border Padding="20" Background="{DynamicResource PrimaryBackgroundGradient}">
            <Grid RowDefinitions="* Auto">
                <StackPanel Grid.Row="0" Spacing="10">
                    <Image Source="{SvgImage /Assets/logo.svg}" Width="220" />

                    <Button Content="Home"
                            Classes.active="{Binding CurrentPage, Converter={StaticResource ActivePageConverter}, ConverterParameter={x:Static data:ApplicationPageNames.HomePage}}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding GoToPageCommand}"
                            CommandParameter="{x:Static data:ApplicationPageNames.HomePage}" />

                    <Button Content="Learn"
                            Classes.active="{Binding CurrentPage, Converter={StaticResource ActivePageConverter}, ConverterParameter={x:Static data:ApplicationPageNames.Learn}}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding GoToPageCommand}"
                            CommandParameter="{x:Static data:ApplicationPageNames.Learn}" />

                    <Button Content="Manage Cards"
                            Classes.active="{Binding CurrentPage, Converter={StaticResource ActivePageConverter}, ConverterParameter={x:Static data:ApplicationPageNames.ManageCards}}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding GoToPageCommand}"
                            CommandParameter="{x:Static data:ApplicationPageNames.ManageCards}" />

                    <Button Content="Manage Categories"
                            Classes.active="{Binding CurrentPage, Converter={StaticResource ActivePageConverter}, ConverterParameter={x:Static data:ApplicationPageNames.ManageCategories}}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding GoToPageCommand}"
                            CommandParameter="{x:Static data:ApplicationPageNames.ManageCategories}" />

                    <Button Content="Manage Tags"
                            Classes.active="{Binding CurrentPage, Converter={StaticResource ActivePageConverter}, ConverterParameter={x:Static data:ApplicationPageNames.ManageTags}}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding GoToPageCommand}"
                            CommandParameter="{x:Static data:ApplicationPageNames.ManageTags}" />
                </StackPanel>

                <Grid Grid.Row="1" ColumnDefinitions="* Auto Auto">
                    <TextBlock Grid.Column="0" Text="{Binding Username}" FontSize="20" VerticalAlignment="Center" />

                    <Button Grid.Column="1"
                            Height="40"
                            Width="40"
                            Classes="transparent"
                            Classes.transparent-active="{Binding CurrentPage, Converter={StaticResource ActivePageConverter}, ConverterParameter={x:Static data:ApplicationPageNames.Settings}}"
                            Command="{Binding GoToPageCommand}"
                            CommandParameter="{x:Static data:ApplicationPageNames.Settings}">
                        <materialIcons:MaterialIcon Kind="SettingsOutline" FontSize="20" />
                    </Button>

                    <Button Grid.Column="2"
                            Classes="transparent"
                            Height="40"
                            Width="40">
                        <materialIcons:MaterialIcon Kind="Logout" FontSize="20" />
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" />
    </Grid>
</Window>
